{
  "name": "@the-platform/db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:seed": "node --import tsx src/seed.ts",
    "lint": "eslint src drizzle.config.ts --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@the-platform/shared": "file:../shared",
    "drizzle-orm": "^0.43.1",
    "ioredis": "^5.10.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.1"
  }
}

{
  "name": "@the-platform/worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "lint": "eslint src --max-warnings=0",
    "repair:notifications": "NOTIFICATION_REPAIR_MODE=repair-notifications tsx src/index.ts",
    "start": "tsx src/index.ts",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@the-platform/db": "file:../../packages/db",
    "@the-platform/shared": "file:../../packages/shared"
  },
  "devDependencies": {
    "tsx": "^4.19.4"
  }
}

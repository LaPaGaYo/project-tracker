{
  "name": "project-tracker",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "docker compose up -d postgres redis && turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "npm run test:contracts && turbo run test",
    "test:contracts": "node --test tests/phase1-foundation-contract.test.mjs",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "npm run db:generate --workspace @the-platform/db",
    "db:migrate": "npm run db:migrate --workspace @the-platform/db",
    "db:seed": "npm run db:seed --workspace @the-platform/db"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@next/eslint-plugin-next": "^15.3.1",
    "@types/node": "^24.0.1",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1"
  },
  "engines": {
    "node": ">=20"
  }
}
